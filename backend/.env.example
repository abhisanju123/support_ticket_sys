# Server
PORT=3000
NODE_ENV=development

# MongoDB
# Local:
# MONGODB_URI=mongodb://localhost:27017/support_tickets
# Atlas (replace USER, PASSWORD, and cluster host):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/support_tickets?retryWrites=true&w=majority&appName=Cluster0
# Windows: if Atlas fails with querySrv ECONNREFUSED, the app prepends 8.8.8.8 / 1.1.1.1 for SRV lookups.
# Override or disable with a comma-separated list (empty = skip supplemental DNS):
# MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
MONGODB_URI=mongodb://localhost:27017/support_tickets
MONGODB_DB_NAME=support_tickets
MONGODB_MAX_RETRIES=5
MONGODB_RETRY_DELAY_MS=5000

# Auth (JWT access tokens)
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=30m

# Seed users (optional overrides — defaults match sample dev users)
# Default password for all seeded users (used on insert / when password is missing):
# SEED_DEFAULT_PASSWORD=Password123!
# SEED_USER_JOHN_NAME=John Doe
# SEED_USER_JOHN_EMAIL=john@example.com
# SEED_USER_JOHN_ROLE=support_agent
# SEED_USER_JANE_NAME=Jane Smith
# SEED_USER_JANE_EMAIL=jane@example.com
# SEED_USER_JANE_ROLE=support_manager
# SEED_USER_ALEX_NAME=Alex Johnson
# SEED_USER_ALEX_EMAIL=alex@example.com
# SEED_USER_ALEX_ROLE=support_agent
